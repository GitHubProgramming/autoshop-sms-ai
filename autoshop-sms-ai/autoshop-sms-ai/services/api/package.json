{
  "name": "@autoshop/api",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node -e \"require('./src/db/migrate').runMigrations()\"",
    "seed": "ts-node src/db/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@autoshop/shared": "*",
    "@clerk/backend": "^1.0.0",
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "bullmq": "^5.3.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "stripe": "^14.15.0",
    "twilio": "^5.0.0",
    "googleapis": "^140.0.0",
    "openai": "^4.29.0",
    "zod": "^3.22.4",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/pg": "^8.11.0",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0"
  }
}
