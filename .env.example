# AutoShop SMS AI — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://autoshop:autoshop_secret@localhost:5432/autoshop
POSTGRES_USER=autoshop
POSTGRES_PASSWORD=autoshop_secret
POSTGRES_DB=autoshop

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379/0
REDIS_PASSWORD=redis_secret

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=change_me_to_32_char_random_string_here
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password
N8N_WEBHOOK_URL=http://localhost:5678
# Internal URL the API worker uses to call n8n webhooks (use http://n8n:5678 inside Docker)
N8N_INTERNAL_URL=http://localhost:5678

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_STARTER=price_REPLACE_ME
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_PREMIUM=price_REPLACE_ME

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACREPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_MESSAGING_SERVICE_SID=MGREPLACE_ME

# Skip Twilio signature validation in local dev (set to false in staging/prod)
SKIP_TWILIO_VALIDATION=true

# ── Test tenant (shared number — skips Twilio purchase for test signups) ──────
TEST_SHARED_PHONE_NUMBER=+13257523890

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=https://autoshopsmsai.com/auth/google/callback

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=change_me_to_random_64_char_string
LOG_LEVEL=info

# ── Public origin (used for OAuth redirects back to frontend) ─────────────
PUBLIC_ORIGIN=https://autoshopsmsai.com

# ── GitHub (read-only project board in admin dashboard) ───────────────────
GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_REPO=owner/repo
